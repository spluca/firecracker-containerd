#!/usr/bin/env bash
#
# Pre-commit hook for firecracker-containerd
# Runs the critical checks from CI to catch failures before pushing.
#
# Install:
#   ln -sf ../../.githooks/pre-commit .git/hooks/pre-commit
#
# Skip: git commit --no-verify

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

pass()  { echo -e "  ${GREEN}✓${NC} $1"; }
fail()  { echo -e "  ${RED}✗${NC} $1"; }
warn()  { echo -e "  ${YELLOW}⚠${NC} $1"; }

echo "========================================"
echo "Pre-commit checks"
echo "========================================"

STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [ -z "$STAGED" ]; then
    echo "No staged files to check."
    exit 0
fi

FAILED=0

# --- 1. DCO reminder ---
echo ""
echo "1. DCO check reminder..."
echo "  All commits need a Signed-off-by line."
echo "  Use: git commit -s  (or: git commit --amend -s)"
pass "Remembered ✓"

# --- 2. go mod tidy ---
echo ""
echo "2. Checking go mod tidy..."
make tidy >/dev/null 2>&1 || true
TIDY_DIFF=$(git diff --name-only go.mod go.sum 2>/dev/null || true)
if [ -z "$TIDY_DIFF" ]; then
    pass "go.mod/go.sum up to date"
else
    fail "go.mod/go.sum need tidying — run: go mod tidy"
    echo "  Changed: $TIDY_DIFF"
    FAILED=1
fi

# --- 3. Proto generation (optional — needs protoc) ---
echo ""
echo "3. Checking proto generation..."
PROTO_OUTPUT=$(make proto 2>&1) && PROTO_OK=0 || PROTO_OK=$?
if [ "$PROTO_OK" -eq 0 ]; then
    PROTO_DIFF=$(git diff --name-only 2>/dev/null | grep -v "^\\.git/" || true)
    if [ -z "$PROTO_DIFF" ]; then
        pass "Proto files up to date"
    else
        warn "Proto files changed by make proto"
        echo "  Changed: $PROTO_DIFF"
        echo "  Stage with: git add <files>"
    fi
else
    warn "Proto generation skipped (protoc not installed)"
fi

# --- 4. Go build ---
echo ""
echo "4. Checking build..."
BUILD_OUTPUT=$(go build ./... 2>&1) && BUILD_OK=0 || BUILD_OK=$?
if [ "$BUILD_OK" -eq 0 ]; then
    pass "Build OK"
else
    fail "Build failed"
    echo "$BUILD_OUTPUT" | head -5 | sed 's/^/  /'
    FAILED=1
fi

# --- 5. Unit tests (quick, no root) ---
echo ""
echo "5. Running quick tests..."
TEST_OUTPUT=$(DISABLE_ROOT_TESTS=1 go test -short ./... 2>&1) && TEST_OK=0 || TEST_OK=$?
if [ "$TEST_OK" -eq 0 ]; then
    pass "Quick tests pass"
else
    FAIL_COUNT=$(echo "$TEST_OUTPUT" | grep -c "^FAIL" || true)
    if [ "$FAIL_COUNT" -gt 0 ]; then
        warn "$FAIL_COUNT package(s) failed (may need root tools)"
        echo "$TEST_OUTPUT" | grep "^FAIL" | head -5 | sed 's/^/  /'
        echo "  CI runs tests with root; these may pass there"
        echo "  Commit anyway: commit proceeds, fix tests later"
    else
        pass "Quick tests pass (with warnings)"
    fi
fi

echo ""
echo "========================================"
if [ $FAILED -ne 0 ]; then
    echo -e "${RED}✗ Pre-commit checks FAILED${NC}"
    echo "Fix the issues above or use: git commit --no-verify"
    exit 1
else
    echo -e "${GREEN}✓ All pre-commit checks passed${NC}"
    exit 0
fi
